# PostgreSQL (Railway: use the DATABASE_URL from the Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/photo_delivery?schema=public"

# NextAuth — set a long random string in production
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Storage: MVP uses local file storage by default (stores in public/uploads/)
# For production S3 integration, set these environment variables:
# STORAGE_URL="https://your-endpoint.example.com"
# STORAGE_BUCKET="your-bucket-name"
# STORAGE_KEY="your-access-key-id"
# STORAGE_SECRET="your-secret-access-key"
# STORAGE_REGION="auto"
# STORAGE_FORCE_PATH_STYLE="false"

